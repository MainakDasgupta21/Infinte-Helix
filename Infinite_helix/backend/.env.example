# ==============================================
# Infinite Helix – Environment Variables
# Copy this file to .env and fill in your values
# ==============================================

# Flask
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key

# Demo Mode (set to false for production with real Firebase/models)
DEMO_MODE=true
DESKTOP_NOTIFICATIONS=true

# Firebase
FIREBASE_CREDENTIALS_PATH=./config/firebase-credentials.json

# Google Calendar OAuth (fallback when Microsoft is unavailable)
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI = GOOGLE_REDIRECT_URI below (must match exactly)
# 4. Enable "Google Calendar API" under APIs & Services → Library
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/google/callback

# Microsoft Teams / Outlook calendar (PRIMARY provider)
# IT or devs register a single Azure AD app. Employees only click "Connect" and sign in
# with their work Microsoft account; they never need Azure Portal or client IDs.
# 1. https://portal.azure.com → App registrations → New registration
# 2. Redirect URI = web → your MS_REDIRECT_URI (must match exactly)
# 3. API permissions → Microsoft Graph delegated: Calendars.ReadWrite, User.Read
# 4. Certificates & secrets → New client secret
# 5. IMPORTANT: Use the Secret "Value" (shown once at creation), NOT the "Secret ID"
# Optional: set MS_TENANT_ID to your org tenant id (e.g. Amdocs) to restrict sign-in to that org only.
MS_CLIENT_ID=your-microsoft-client-id
MS_CLIENT_SECRET=your-microsoft-client-secret-VALUE-not-secret-id
# Use your Azure AD tenant GUID, or "common" for multi-tenant, "organizations" for work-only
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:5000/api/calendar/callback

# Groq AI Chatbot (free: https://console.groq.com → API Keys)
# Without this key the chatbot falls back to built-in template responses
GROQ_API_KEY=

# AI Models
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment
MODEL_CACHE_DIR=./model_cache

# Tracker
TRACKER_INTERVAL_SECONDS=30
NUDGE_COOLDOWN_MINUTES=30
IDLE_THRESHOLD_SECONDS=60
FATIGUE_THRESHOLD_MINUTES=120
